generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Representa un comercio suscripto a la plataforma
model Tenant {
  id          String            @id @default(cuid())
  nombre      String
  email       String            @unique
  slug        String            @unique
  logoUrl     String?
  telefono    String?
  direccion   String?
  ciudad      String?
  plan        PlanTipo          @default(FREE)
  activo      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  cuit        String?
  descripcion String?
  facebook    String?
  instagram   String?
  provincia   String?
  sitioWeb    String?
  cajas       Caja[]
  categorias  Categoria[]
  movimientos Movimiento[]
  precios     PrecioHistorico[]
  productos   Producto[]
  proveedores Proveedor[]
  suscripcion Suscripcion?
  usuarios    UsuarioTenant[]
  ventas      Venta[]

  @@index([plan])
  @@index([activo])
  @@index([createdAt])
}

model Suscripcion {
  id                 String    @id @default(cuid())
  tenantId           String    @unique
  plan               PlanTipo
  estado             String    @default("pending")
  mpPreapprovalId    String?
  mpSubscriptionId   String?
  proximoVencimiento DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([estado])
  @@index([proximoVencimiento])
}

model UsuarioTenant {
  id         String    @id @default(cuid())
  tenantId   String
  supabaseId String    @unique
  nombre     String
  email      String
  rol        RolTenant @default(EMPLEADO)
  activo     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([supabaseId])
  @@index([email])
  @@index([tenantId, activo])
  @@index([tenantId, rol])
}

model Categoria {
  id          String     @id @default(cuid())
  tenantId    String
  nombre      String
  descripcion String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productos   Producto[]

  @@unique([tenantId, nombre])
  @@index([tenantId])
}

model Proveedor {
  id        String     @id @default(cuid())
  tenantId  String
  nombre    String
  telefono  String?
  email     String?
  direccion String?
  notas     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  productos Producto[]
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([email])
}

model Producto {
  id             String            @id @default(cuid())
  tenantId       String
  nombre         String
  descripcion    String?
  codigoProducto String?
  codigoBarras   String?
  precio         Float
  costo          Float?
  stock          Int               @default(0)
  stockMinimo    Int               @default(5)
  unidad         String?
  imagen         String?
  imagenes       String[]          @default([])
  activo         Boolean           @default(true)
  categoriaId    String?
  proveedorId    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  movimientos    Movimiento[]
  precios        PrecioHistorico[]
  categoria      Categoria?        @relation(fields: [categoriaId], references: [id])
  proveedor      Proveedor?        @relation(fields: [proveedorId], references: [id])
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ventaItems     VentaItem[]

  @@unique([tenantId, codigoProducto])
  @@unique([tenantId, codigoBarras])
  @@index([tenantId])
  @@index([tenantId, activo])
  @@index([tenantId, categoriaId])
  @@index([tenantId, nombre])
  @@index([tenantId, stock])
  @@index([tenantId, activo, nombre])
  @@index([codigoBarras])
  @@index([tenantId, activo, stock])
  @@index([categoriaId])
  @@index([proveedorId])
}

model PrecioHistorico {
  id          String   @id @default(cuid())
  tenantId    String
  productoId  String
  precioViejo Float
  precioNuevo Float
  motivo      String?
  usuarioId   String?
  createdAt   DateTime @default(now())
  producto    Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productoId])
  @@index([createdAt])
}

model Venta {
  id            String       @id @default(cuid())
  tenantId      String
  total         Float
  subtotal      Float?
  descuento     Float?       @default(0)
  metodoPago    String
  clienteNombre String?
  clienteDni    String?
  observaciones String?
  usuarioId     String?
  usuarioNombre String?
  createdAt     DateTime     @default(now())
  movimientos   Movimiento[]
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items         VentaItem[]

  @@index([tenantId])
  @@index([tenantId, metodoPago])
  @@index([tenantId, usuarioId])
  @@index([clienteNombre])
  @@index([clienteDni])
  @@index([tenantId, createdAt])
  @@index([tenantId, metodoPago, createdAt])
  @@index([tenantId, createdAt(sort: Desc)], map: "Venta_tenantId_createdAt_desc_idx")
}

model VentaItem {
  id         String   @id @default(cuid())
  ventaId    String
  productoId String
  nombre     String
  cantidad   Int
  precioUnit Float
  subtotal   Float
  producto   Producto @relation(fields: [productoId], references: [id])
  venta      Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  @@index([ventaId])
  @@index([productoId])
  @@index([productoId, ventaId])
  @@index([ventaId, productoId])
}

model Movimiento {
  id                String         @id @default(cuid())
  tenantId          String
  productoId        String
  productoNombre    String
  tipo              TipoMovimiento
  cantidad          Int
  stockAnterior     Int?
  stockResultante   Int?
  motivo            String?
  ventaId           String?
  usuarioId         String?
  usuarioNombre     String?
  cancelado         Boolean        @default(false)
  motivoCancelacion String?
  canceladoPor      String?
  canceladoAt       DateTime?
  createdAt         DateTime       @default(now())
  producto          Producto       @relation(fields: [productoId], references: [id])
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  venta             Venta?         @relation(fields: [ventaId], references: [id])

  @@index([tenantId])
  @@index([tenantId, productoId])
  @@index([tenantId, tipo])
  @@index([tenantId, cancelado, createdAt])
  @@index([productoId, createdAt])
  @@index([ventaId])
  @@index([tenantId, tipo, createdAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, createdAt(sort: Desc)], map: "Movimiento_tenantId_createdAt_desc_idx")
}

model Caja {
  id            String           @id @default(cuid())
  tenantId      String
  usuarioId     String?
  usuarioNombre String?
  saldoInicial  Float
  saldoFinal    Float?
  saldoContado  Float?
  diferencia    Float?
  observaciones String?
  abiertaAt     DateTime         @default(now())
  cerradaAt     DateTime?
  estado        String           @default("ABIERTA")
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  movimientos   MovimientoCaja[]

  @@index([tenantId])
  @@index([tenantId, estado])
  @@index([tenantId, abiertaAt])
  @@index([tenantId, estado, abiertaAt])
  @@index([tenantId, cerradaAt(sort: Desc)], map: "Caja_tenantId_cerradaAt_desc_idx")
}

model MovimientoCaja {
  id            String             @id @default(cuid())
  tenantId      String
  cajaId        String
  tipo          TipoMovimientoCaja
  monto         Float
  descripcion   String?
  ventaId       String?
  usuarioId     String?
  usuarioNombre String?
  createdAt     DateTime           @default(now())
  metodoPago    String?
  caja          Caja               @relation(fields: [cajaId], references: [id], onDelete: Cascade)

  @@index([cajaId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([cajaId, tipo])
  @@index([ventaId])
  @@index([cajaId, createdAt])
}

enum PlanTipo {
  FREE
  PRO
  ENTERPRISE
}

enum RolTenant {
  PROPIETARIO
  ADMINISTRADOR
  EMPLEADO
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
  VENTA
  AJUSTE
}

enum TipoMovimientoCaja {
  APERTURA
  VENTA_EFECTIVO
  INGRESO
  EGRESO
  CIERRE
  VENTA_VIRTUAL
}
