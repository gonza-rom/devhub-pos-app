// prisma/schema.prisma
// DevHub POS — Schema Multi-Tenant
// ──────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PlanTipo {
  FREE
  PRO
  ENTERPRISE
}

enum RolTenant {
  PROPIETARIO    // Puede gestionar plan, usuarios y todo
  ADMINISTRADOR  // Acceso total al negocio
  EMPLEADO       // Solo ventas y consultas
}

// Tipo de movimiento de stock
enum TipoMovimiento {
  ENTRADA   // Carga de stock manual
  SALIDA    // Egreso manual de stock
  VENTA     // Descuento automático por venta
  AJUSTE    // Corrección de inventario
}

// ══════════════════════════════════════════════════════════════
// MODELOS DE PLATAFORMA (globales, sin tenantId)
// ══════════════════════════════════════════════════════════════

/// Representa un comercio suscripto a la plataforma
model Tenant {
  id        String   @id @default(cuid())
  nombre    String
  email     String   @unique
  slug      String   @unique
  logoUrl   String?
  telefono  String?
  direccion String?
  descripcion String?
  cuit        String?
  sitioWeb    String?
  instagram   String?
  facebook    String?
  provincia   String?
  ciudad    String?
  plan      PlanTipo @default(FREE)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  suscripcion   Suscripcion?
  usuarios      UsuarioTenant[]
  productos     Producto[]
  ventas        Venta[]
  movimientos   Movimiento[]
  categorias    Categoria[]
  proveedores   Proveedor[]
  precios       PrecioHistorico[]
  cajas Caja[]
}

model Suscripcion {
  id                 String    @id @default(cuid())
  tenantId           String    @unique
  plan               PlanTipo
  estado             String    @default("pending")
  mpPreapprovalId    String?
  mpSubscriptionId   String?
  proximoVencimiento DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model UsuarioTenant {
  id         String    @id @default(cuid())
  tenantId   String
  supabaseId String    @unique
  nombre     String
  email      String
  rol        RolTenant @default(EMPLEADO)
  activo     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([supabaseId])
}

model Categoria {
  id          String     @id @default(cuid())
  tenantId    String
  nombre      String
  descripcion String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productos Producto[]

  @@unique([tenantId, nombre])
  @@index([tenantId])
}

model Proveedor {
  id        String   @id @default(cuid())
  tenantId  String
  nombre    String
  telefono  String?
  email     String?
  direccion String?
  notas     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productos Producto[]

  @@index([tenantId])
}

model Producto {
  id             String   @id @default(cuid())
  tenantId       String
  nombre         String
  descripcion    String?
  codigoProducto String?
  codigoBarras   String?
  precio         Float
  costo          Float?
  stock          Int      @default(0)
  stockMinimo    Int      @default(5)
  unidad         String?
  imagen         String?
  imagenes       String[] @default([])
  activo         Boolean  @default(true)
  categoriaId    String?
  proveedorId    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoria Categoria?        @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  proveedor Proveedor?        @relation(fields: [proveedorId], references: [id], onDelete: SetNull)
  ventaItems VentaItem[]
  movimientos Movimiento[]
  precios    PrecioHistorico[]

  @@unique([tenantId, codigoProducto])
  @@unique([tenantId, codigoBarras])
  @@index([tenantId])
  @@index([tenantId, activo])
  @@index([tenantId, categoriaId])
  @@index([tenantId, nombre])          // búsqueda por nombre
  @@index([tenantId, stock])            // filtro stock bajo
  @@index([tenantId, activo, nombre])   // lista principal
}

model PrecioHistorico {
  id          String   @id @default(cuid())
  tenantId    String
  productoId  String
  precioViejo Float
  precioNuevo Float
  motivo      String?
  usuarioId   String?
  createdAt   DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productoId])
}

model Venta {
  id            String   @id @default(cuid())
  tenantId      String
  total         Float
  subtotal      Float?
  descuento     Float?   @default(0)
  metodoPago    String
  clienteNombre String?
  clienteDni    String?
  observaciones String?
  usuarioId     String?
  usuarioNombre String?
  createdAt     DateTime @default(now())

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  VentaItem[]
  movimientos Movimiento[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, metodoPago])
  @@index([tenantId, usuarioId])        // filtro por cajero
}

model VentaItem {
  id         String @id @default(cuid())
  ventaId    String
  productoId String
  nombre     String
  cantidad   Int
  precioUnit Float
  subtotal   Float

  venta    Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@index([ventaId])
  @@index([productoId])
}

model Movimiento {
  id                String         @id @default(cuid())
  tenantId          String
  productoId        String
  productoNombre    String
  tipo              TipoMovimiento
  cantidad          Int
  stockAnterior     Int?
  stockResultante   Int?
  motivo            String?
  ventaId           String?
  usuarioId         String?
  usuarioNombre     String?
  cancelado         Boolean        @default(false)
  motivoCancelacion String?
  canceladoPor      String?
  canceladoAt       DateTime?
  createdAt         DateTime       @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)
  venta    Venta?   @relation(fields: [ventaId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, productoId])
  @@index([tenantId, tipo])
  @@index([tenantId, cancelado, createdAt])  // filtro cancelados
}

enum TipoMovimientoCaja {
  APERTURA
  VENTA_EFECTIVO
  VENTA_VIRTUAL    // ← nuevo
  INGRESO
  EGRESO
  CIERRE
}

/// Sesión de caja (una por día/turno)
model Caja {
  id              String    @id @default(cuid())
  tenantId        String
  usuarioId       String?
  usuarioNombre   String?
  saldoInicial    Float
  saldoFinal      Float?    // null mientras está abierta
  saldoContado    Float?    // lo que el cajero contó al cerrar
  diferencia      Float?    // saldoFinal - saldoContado
  observaciones   String?
  abiertaAt       DateTime  @default(now())
  cerradaAt       DateTime?
  estado          String    @default("ABIERTA") // ABIERTA | CERRADA

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  movimientos     MovimientoCaja[]

  @@index([tenantId])
  @@index([tenantId, estado])
  @@index([tenantId, abiertaAt])
}

/// Movimientos dentro de una sesión de caja
model MovimientoCaja {
  id            String              @id @default(cuid())
  tenantId      String
  cajaId        String
  tipo          TipoMovimientoCaja
  monto         Float
  descripcion   String?
  ventaId       String?             // referencia si es VENTA_EFECTIVO
  usuarioId     String?
  usuarioNombre String?
  metodoPago String?
  createdAt     DateTime            @default(now())

  caja    Caja   @relation(fields: [cajaId], references: [id], onDelete: Cascade)


  @@index([cajaId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
}