// ══════════════════════════════════════════════════════════════

enum TipoMovimientoCaja {
  APERTURA       // Saldo inicial al abrir
  VENTA_EFECTIVO // Ingreso automático por venta en efectivo
  INGRESO        // Ingreso manual (ej: depósito)
  EGRESO         // Egreso manual (ej: pago proveedor, retiro)
  CIERRE         // Registro del cierre
}



// ══════════════════════════════════════════════════════════════
// AGREGAR estos modelos al final del schema.prisma
// ══════════════════════════════════════════════════════════════

/// Sesión de caja (una por día/turno)
model Caja {
  id              String    @id @default(cuid())
  tenantId        String
  usuarioId       String?
  usuarioNombre   String?
  saldoInicial    Float
  saldoFinal      Float?    // null mientras está abierta
  saldoContado    Float?    // lo que el cajero contó al cerrar
  diferencia      Float?    // saldoFinal - saldoContado
  observaciones   String?
  abiertaAt       DateTime  @default(now())
  cerradaAt       DateTime?
  estado          String    @default("ABIERTA") // ABIERTA | CERRADA

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  movimientos     MovimientoCaja[]

  @@index([tenantId])
  @@index([tenantId, estado])
  @@index([tenantId, abiertaAt])
}

/// Movimientos dentro de una sesión de caja
model MovimientoCaja {
  id            String              @id @default(cuid())
  tenantId      String
  cajaId        String
  tipo          TipoMovimientoCaja
  monto         Float
  descripcion   String?
  ventaId       String?             // referencia si es VENTA_EFECTIVO
  usuarioId     String?
  usuarioNombre String?
  createdAt     DateTime            @default(now())

  caja    Caja   @relation(fields: [cajaId], references: [id], onDelete: Cascade)

  @@index([cajaId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
}
