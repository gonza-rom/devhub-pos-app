# ══════════════════════════════════════════════════════════════
# DevHub POS — Variables de entorno
# Copiá este archivo como .env.local y completá los valores
# cp .env.example .env.local
# ══════════════════════════════════════════════════════════════

# ── Supabase ───────────────────────────────────────────────────
# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Settings → API → service_role (NUNCA exponerla al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Base de datos (Prisma) ─────────────────────────────────────
# Settings → Database → Transaction pooler (puerto 6543)
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Settings → Database → Session pooler (puerto 5432)
DIRECT_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Sesión JWT (cookie firmada del tenant) ─────────────────────
# Generalo con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=cambia_esto_por_un_string_random_de_64_caracteres_minimo

# ── Cloudinary (imágenes de productos) ────────────────────────
# Dashboard de Cloudinary → Cloud name
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=tu_cloud_name

# Settings → Upload → Upload presets → nombre del preset unsigned
NEXT_PUBLIC_CLOUDINARY_PRESET=devhub-pos

# ── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Mercado Pago (opcional, para suscripciones) ───────────────
# developers.mercadopago.com → Tus integraciones → Credenciales
# MP_ACCESS_TOKEN=APP_USR-...
# MP_PUBLIC_KEY=APP_USR-...
# MP_WEBHOOK_SECRET=tu_webhook_secret
